# ── Suivi Chantiers — Variables d'environnement ──────────────────────────────
# Copier en .env pour le dev local, ou configurer dans Dokploy

# Clé secrète Flask (OBLIGATOIRE en production — chaîne longue et aléatoire)
SECRET_KEY=change-me-with-a-very-long-random-string

# URL PostgreSQL
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Dokploy : copier l'URL fournie par le service PostgreSQL de Dokploy
DATABASE_URL=postgresql://suivi:suivi@localhost:5432/suivi_chantiers
